{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Medjed-maker/proteus/schemas/phonology_rule_file.schema.json",
  "title": "Phonology Rule File Schema",
  "description": "Schema for phonological rule definition files used in Proteus phonological search.",
  "type": "object",
  "required": ["meta", "rules"],
  "additionalProperties": true,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "status", "review_status", "citation_ready", "license", "source_notes"],
      "properties": {
        "version": {
          "type": "string",
          "description": "Rule file semantic version (MAJOR.MINOR.PATCH)",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "updated_at": {
          "type": "string",
          "description": "ISO-8601 date/time of last rule change (documentation only)",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["provisional", "draft", "stable"],
          "description": "Research data status"
        },
        "review_status": {
          "type": "string",
          "enum": ["not_expert_reviewed", "expert_reviewed", "peer_reviewed"],
          "description": "Expert review state"
        },
        "citation_ready": {
          "type": "boolean",
          "description": "Whether the ruleset is ready for academic citation"
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier or project license",
          "examples": ["MIT", "CC-BY-SA-4.0"]
        },
        "source_notes": {
          "type": "array",
          "description": "Human-readable provenance and status notes",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "rules": {
      "type": "array",
      "description": "List of phonological rules",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["id", "name_en", "name_ja", "input", "output", "context", "dialects", "period", "references", "examples"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "output": {
                "const": ""
              }
            },
            "required": ["output"]
          },
          "then": {
            "properties": {
              "change_type": {
                "const": "deletion"
              }
            },
            "required": ["change_type"]
          }
        },
        {
          "if": {
            "properties": {
              "change_type": {
                "const": "deletion"
              }
            },
            "required": ["change_type"]
          },
          "then": {
            "properties": {
              "output": {
                "const": ""
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "change_type": {
                "const": "retention"
              }
            },
            "required": ["change_type"]
          },
          "then": {
            "properties": {
              "output": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "input": {
                "const": ""
              }
            },
            "required": ["input"]
          },
          "then": {
            "properties": {
              "is_insertion": {
                "const": true
              }
            },
            "required": ["is_insertion"]
          }
        },
        {
          "if": {
            "properties": {
              "is_insertion": {
                "const": true
              }
            },
            "required": ["is_insertion"]
          },
          "then": {
            "properties": {
              "input": {
                "const": ""
              }
            }
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique rule identifier",
          "pattern": "^[A-Z]{3}-[0-9]{3}$"
        },
        "name_en": {
          "type": "string",
          "description": "English rule name"
        },
        "name_ja": {
          "type": "string",
          "description": "Japanese rule name"
        },
        "input": {
          "type": "string",
          "description": "Source phone(s) in IPA notation"
        },
        "is_insertion": {
          "const": true,
          "description": "True when an empty-input rule explicitly models insertion on the query side."
        },
        "output": {
          "type": "string",
          "description": "Resulting phone(s) in IPA notation. Empty string only for deletion rules.",
          "minLength": 0
        },
        "context": {
          "oneOf": [
            {
              "type": "string",
              "description": "Phonological environment (_ = position, # = word boundary, ... = any same-word span, V = any vowel, {a,o} = choice/set of alternatives)"
            },
            {
              "type": "null",
              "description": "Unconditioned rule (applies in all environments)"
            }
          ]
        },
        "dialects": {
          "type": "array",
          "description": "Applicable dialect(s) or chronological varieties. Restricted to the canonical Ancient Greek dialect vocabulary; only 'attic' and 'koine' are public dialect_hint values, the rest are explanation metadata.",
          "items": {
            "type": "string",
            "enum": [
              "attic",
              "cretan",
              "cyprian",
              "doric",
              "elean",
              "ionic",
              "ionic_east",
              "koine",
              "lesbian",
              "northwest_greek",
              "severe_doric",
              "west_greek"
            ]
          },
          "minItems": 1
        },
        "period": {
          "type": "string",
          "description": "Chronological range for the sound change"
        },
        "references": {
          "type": "array",
          "description": "Short-form scholarly references (e.g., Buck §68, Smyth §125)",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "examples": {
          "type": "array",
          "description": "Attested contrastive examples with glosses",
          "items": {
            "$ref": "#/$defs/example"
          },
          "minItems": 1
        },
        "change_type": {
          "type": "string",
          "enum": ["retention", "deletion"],
          "description": "Optional change classification. Empty output requires \"deletion\"."
        },
        "note": {
          "type": "string",
          "description": "Clarification for overlapping environments or special constraints"
        },
        "lemma_constraints": {
          "type": "object",
          "description": "Optional constraints on lemma patterns",
          "additionalProperties": true
        }
      }
    },
    "example": {
      "type": "object",
      "required": ["standard", "meaning"],
      "properties": {
        "standard": {
          "type": "string",
          "description": "Reference form used for comparison (often the Attic or familiar form)"
        },
        "meaning": {
          "type": "string",
          "description": "English gloss of the example"
        },
        "dialect": {
          "type": "string",
          "description": "Contrasting dialectal or chronological form that illustrates the rule"
        },
        "phonetic": {
          "type": "string",
          "description": "IPA transcription showing the sound-level change, e.g., '[bíos] → [víos]'"
        },
        "reconstruction": {
          "type": "string",
          "description": "Reconstructed (unattested) form, prefixed with * per convention"
        }
      },
      "anyOf": [
        {
          "required": ["dialect"],
          "description": "Example must have at least one contrast field: dialect, phonetic, or reconstruction"
        },
        {
          "required": ["phonetic"],
          "description": "Example must have at least one contrast field: dialect, phonetic, or reconstruction"
        },
        {
          "required": ["reconstruction"],
          "description": "Example must have at least one contrast field: dialect, phonetic, or reconstruction"
        }
      ]
    }
  }
}
