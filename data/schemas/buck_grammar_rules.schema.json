{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Medjed-maker/proteus/schemas/buck_grammar_rules.schema.json",
  "title": "Buck Grammar Rules Schema",
  "description": "Shape schema for provisional Buck-normalized grammar rule summaries.",
  "type": "object",
  "required": ["meta", "rules"],
  "additionalProperties": true,
  "properties": {
    "meta": {
      "$ref": "#/$defs/buckMetadata"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "buckMetadata": {
      "type": "object",
      "description": "Shared Buck document metadata. additionalProperties stays permissive for forward compatibility. Keep this definition identical across all buck_*.schema.json files (guarded by tests/test_buck_data_files.py).",
      "required": ["status", "review_status", "citation_ready", "source_notes"],
      "additionalProperties": true,
      "allOf": [
        {
          "description": "citation_ready: true requires review_status: expert_reviewed (project-wide convention; see docs/REQUIREMENTS.md and docs/API.md).",
          "if": {
            "properties": {
              "citation_ready": {
                "const": true
              }
            },
            "required": ["citation_ready"]
          },
          "then": {
            "properties": {
              "review_status": {
                "const": "expert_reviewed"
              }
            },
            "required": ["review_status"]
          }
        }
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["provisional", "draft", "stable"]
        },
        "review_status": {
          "type": "string",
          "enum": ["not_expert_reviewed", "expert_reviewed", "peer_reviewed"]
        },
        "citation_ready": {
          "type": "boolean"
        },
        "source_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "rule": {
      "type": "object",
      "description": "Entry-level definition: additionalProperties is strict so field typos fail validation instead of being silently ignored.",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "buck_section": {
          "$ref": "#/$defs/section"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "transformation": {
          "$ref": "#/$defs/transformation"
        },
        "affected_dialects": {
          "$ref": "#/$defs/stringList"
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/variant"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transformation": {
      "type": "object",
      "description": "Entry-level definition: additionalProperties is strict so field typos fail validation instead of being silently ignored.",
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "variant": {
      "type": "object",
      "description": "Variant entries are heterogeneous summaries; additionalProperties stays permissive and only the dialects field is shape-checked.",
      "additionalProperties": true,
      "properties": {
        "dialects": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "section": {
      "type": ["string", "integer", "number"]
    }
  }
}
